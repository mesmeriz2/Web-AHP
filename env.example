# AHP 프로젝트 환경 변수 예시
# 복사 후 .env 로 저장하고 값을 채운 뒤 사용하세요.
# 문서: docs/env-admin-password.md, docs/code-review-improvements.md

# ---- Docker / Compose ----
PROJECT_NAME=ahp
POSTGRES_DB=ahp
POSTGRES_USER=ahp
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432
BACKEND_PORT=8006
FRONTEND_PORT=5175
DATABASE_URL=postgresql://ahp:your_postgres_password@db:5432/ahp

# ---- Backend (FastAPI) ----
PROJECT_NAME=ahp
APP_ENV=development
BACKEND_PORT=8006
FRONTEND_PORT=5175
DATABASE_URL=postgresql://ahp:your_postgres_password@localhost:5432/ahp
MIN_PARTICIPANTS=1
MAX_PARTICIPANTS=20
CR_THRESHOLD=0.1
AHP_RI_TABLE_PATH=ahp_ri.json
# CORS: 백엔드 기본값에 localhost, mem.photos, mem.photos:15175(https/http) 포함. 추가만 넣으면 됨.
CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
AHP_MAX_ITER=100
AHP_TOLERANCE=1e-8
PROJECT_CODE_LENGTH=8
ADMIN_CODE_LENGTH=8
PARTICIPANT_CODE_LENGTH=8
ADMIN_ID=mesmerize
ADMIN_PASSWORD_SALT=your_salt_string
ADMIN_PASSWORD_HASH=your_64_char_sha256_hex
ADMIN_JWT_SECRET=your_jwt_secret
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRES_MINUTES=60

# ---- Multi-user (RBAC) ----
# 최초 시작 시 생성되는 Super Admin 계정
INITIAL_SUPER_ADMIN_EMAIL=admin@ahp.local
INITIAL_SUPER_ADMIN_USERNAME=admin
INITIAL_SUPER_ADMIN_PASSWORD=admin1234

# ---- Frontend (Vite) ----
# 로컬/Docker 로컬: VITE_API_BASE_URL=http://localhost:8006
# 시놀로지 역프록시(mem.photos:15175): 비우면 상대 경로 사용 → CORS 불필요 (VITE_API_BASE_URL=)
VITE_API_BASE_URL=http://localhost:8006
# Vite /api 프록시 대상. 시놀로지에서 역프록시가 프론트로만 올 때 사용. Docker 기본: http://backend:8000
# VITE_PROXY_API_TARGET=http://backend:8000
# 시놀로지 역프록시에서 HMR이 필요할 때만 host/port를 함께 설정하세요.
# 로컬 개발에서는 아래 두 값을 비워둡니다.
# VITE_HMR_HOST=mem.photos
# VITE_HMR_PORT=15175
VITE_CR_THRESHOLD=0.1
# 쌍대비교 스케일: 쉼표 구분, 1 포함, 양수만. 예: 1,2,3,4,5,6,7,8,9
VITE_PAIRWISE_SCALE=1,2,3,4,5,6,7,8,9
